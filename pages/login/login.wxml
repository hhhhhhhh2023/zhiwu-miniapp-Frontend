<!--pages/login/login.wxml-->
<view class="login-container">
  <!-- 装饰曲线 -->
  <view class="decor-curve"></view>
  
  <!-- 标题区域 -->
  <view class="login-title">
    <text class="title-cn">登录</text>
    <text class="title-en">Sign in</text>
  </view>

  <!-- 表单区域 -->
  <view class="login-form">
    <view class="form-item">
      <input class="form-input" placeholder="手机号/账号" bindinput="onPhoneInput" />
    </view>
    <view class="form-item">
      <input class="form-input" placeholder="密码" password="{{true}}" bindinput="onPwdInput" />
    </view>
    <view class="forget-pwd" bindtap="handleForgetPwd">
      <text>忘记密码 ></text>
    </view>
  </view>

  <!-- 按钮区域 -->
  <view class="login-buttons">
    <button class="btn-login" bindtap="handleLogin">登录</button>
    <button class="btn-register" bindtap="handleRegister">注册</button>
  </view>

  <!-- 底部Logo（纯CSS实现花盆+文字） -->
  <view class="login-footer">
    <view class="logo">
      <view class="logo-pot">
        <view class="pot-body"></view>
        <view class="pot-leaf"></view>
      </view>
      <text class="logo-text">植悟</text>
    </view>
  </view>
</view>