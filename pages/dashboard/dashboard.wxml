<view class="page">
  <view class="title-wrap">
    <text class="title-cn">我的花园</text>
    <text class="title-en">Garden</text>
  </view>

  <view class="remind-card">
    <view class="remind-head">
      <text>智慧提醒</text>
    </view>
    <view class="remind-item-row" wx:for="{{reminders}}" wx:key="id">
      <view class="remind-item {{item.checked ? 'done' : ''}}">{{item.text}}</view>
      <image class="check-btn" src="{{item.checked ? '/images/remind-check-on.png' : '/images/remind-check-off.png'}}" mode="aspectFit" data-id="{{item.id}}" bindtap="onToggleReminder"></image>
    </view>
  </view>

  <view class="chips">
    <block wx:for="{{tabs}}" wx:key="*this">
      <view class="chip {{activeTab===item?'chip-active':''}}" data-tab="{{item}}" bindtap="onSwitchTab">{{item}}</view>
    </block>
  </view>

  <view class="grid">
    <block wx:for="{{plants}}" wx:key="id">
      <view class="card">
        <image class="card-img" src="/images/plant-placeholder.png" mode="aspectFill"></image>
        <view class="card-name">{{item.name}}</view>
        <view class="card-sub">距离下次浇水还有：{{item.days}}天</view>
      </view>
    </block>
  </view>

  <view class="fab" bindtap="onAddPlant">+</view>
</view>