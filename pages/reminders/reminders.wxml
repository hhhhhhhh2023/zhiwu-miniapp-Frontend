<view class="page">
  <view class="header">
    <text class="back" bindtap="onBack">←</text>
    <text class="title">添加植物</text>
    <text class="done" bindtap="onSubmit">完成</text>
  </view>

  <view class="label-row">
    <text class="label-cn">植物照片</text>
    <text class="label-en">Photo</text>
  </view>

  <view class="photo-wrap">
    <view class="photo-box" bindtap="onPickPhoto">
      <image wx:if="{{photo}}" class="photo" src="{{photo}}" mode="aspectFill"></image>
      <view wx:else class="photo-empty">
        <text class="plus">＋</text>
        <text class="photo-tip">点击添加植物照片</text>
      </view>
    </view>
    <text class="emoji">🪴</text>
  </view>

  <view class="form">
    <view class="field">
      <input placeholder="植物名称" value="{{form.name}}" bindinput="onInputName" />
    </view>
    <view class="field">
      <input placeholder="植物品种" value="{{form.species}}" bindinput="onInputSpecies" />
    </view>
    <view class="field">
      <input placeholder="种植日期" value="{{form.date}}" bindinput="onInputDate" />
    </view>
    <view class="field">
      <input placeholder="栽培方式" value="{{form.method}}" bindinput="onInputMethod" />
    </view>
  </view>
</view>
