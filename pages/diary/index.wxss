/* pages/diary/index.wxss */

/* 基础变量 */
page {
  --primary-green: #5a8f3e;
  --light-green: #8bc34a;
  --bg-green: #f0f7e6;
  --card-bg: #fafdf6;
  --text-dark: #333333;
  --text-gray: #666666;
  --text-light: #999999;
  --water-blue: #e3f2fd;
  --water-text: #1976d2;
  --fertilize-yellow: #fff3e0;
  --fertilize-text: #e65100;
  --prune-green: #e8f5e9;
  --prune-text: #2e7d32;
  --danger-red: #ff4444;
  
  background-color: var(--bg-green);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 容器 */
.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  position: relative;
}

/* 顶部标题 */
.header {
  display: flex;
  align-items: baseline;
  padding: 40rpx 32rpx 20rpx;
  gap: 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-dark);
}

.title-en {
  font-size: 32rpx;
  color: var(--light-green);
  font-style: italic;
}

/* 天气卡片 */
.weather-card {
  margin: 20rpx 32rpx;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #a8d98a 0%, #8bc34a 100%);
  border-radius: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 195, 74, 0.3);
}

.weather-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.weather-text {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.weather-temp {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.weather-icon {
  position: relative;
  width: 120rpx;
  height: 100rpx;
}

.sun {
  position: absolute;
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(180deg, #ffd54f 0%, #ffb300 100%);
  border-radius: 50%;
  top: 0;
  right: 20rpx;
}

.sun-face {
  position: absolute;
  width: 100%;
  height: 100%;
}

.sun-face::before,
.sun-face::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background: #5d4037;
  border-radius: 50%;
  top: 24rpx;
}

.sun-face::before {
  left: 18rpx;
}

.sun-face::after {
  right: 18rpx;
}

.sun-ray {
  position: absolute;
  width: 4rpx;
  height: 12rpx;
  background: #ffd54f;
  top: -16rpx;
  left: 50%;
  margin-left: -2rpx;
  transform-origin: center 51rpx;
  border-radius: 2rpx;
}

.cloud {
  position: absolute;
  width: 60rpx;
  height: 30rpx;
  background: white;
  border-radius: 30rpx;
  bottom: 10rpx;
  right: 0;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.cloud::before {
  content: '';
  position: absolute;
  width: 35rpx;
  height: 35rpx;
  background: white;
  border-radius: 50%;
  top: -18rpx;
  left: 10rpx;
}

.cloud::after {
  content: '';
  position: absolute;
  width: 25rpx;
  height: 25rpx;
  background: white;
  border-radius: 50%;
  top: -10rpx;
  right: 8rpx;
}

/* 植物卡片轮播 */
.plant-carousel-wrapper {
  margin: 20rpx 32rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.carousel-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ccc;
  transition: all 0.3s ease;
}

.dot.active {
  background: var(--light-green);
  transform: scale(1.2);
}

.plant-swiper {
  height: 200rpx;
}

.plant-card {
  display: flex;
  gap: 24rpx;
  align-items: center;
  height: 100%;
}

.plant-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #e8f5e9;
}

.plant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.plant-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-dark);
}

.plant-detail {
  font-size: 26rpx;
  color: var(--text-gray);
}

.highlight {
  color: var(--primary-green);
  font-weight: 500;
}

/* 时间轴容器 */
.timeline-container {
  flex: 1;
  padding: 0 32rpx;
  height: calc(100vh - 580rpx);
}

.timeline {
  padding-bottom: 120rpx;
}

/* 时间轴项 */
.timeline-item {
  position: relative;
  margin-bottom: 32rpx;
}

.swipe-container {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
}

.entry-content {
  display: flex;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  transition: transform 0.1s ease-out;
  position: relative;
  z-index: 1;
}

.timeline-line {
  position: relative;
  width: 40rpx;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  background: var(--light-green);
  border-radius: 50%;
  border: 4rpx solid var(--bg-green);
}

.timeline-connector {
  position: absolute;
  left: 8rpx;
  top: 24rpx;
  width: 4rpx;
  height: calc(100% + 32rpx);
  background: var(--light-green);
  opacity: 0.4;
}

.entry-main {
  flex: 1;
}

.entry-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.entry-date {
  font-size: 26rpx;
  color: var(--text-dark);
  font-weight: 500;
}

.entry-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
}

.tag-water {
  background: var(--water-blue);
  color: var(--water-text);
}

.tag-fertilize {
  background: var(--fertilize-yellow);
  color: var(--fertilize-text);
}

.tag-prune {
  background: var(--prune-green);
  color: var(--prune-text);
}

.entry-note {
  font-size: 26rpx;
  color: var(--text-gray);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.entry-images {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.entry-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: var(--danger-red);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 16rpx 16rpx 0;
}

.delete-text {
  color: white;
  font-size: 28rpx;
}

/* 悬浮添加按钮 */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--primary-green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(90, 143, 62, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 56rpx;
  color: white;
  line-height: 1;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 99;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
}

.tab-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-home,
.icon-message,
.icon-plant,
.icon-profile {
  width: 48rpx;
  height: 48rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  opacity: 0.5;
}

.icon-home.active,
.icon-message.active,
.icon-plant.active,
.icon-profile.active {
  opacity: 1;
}

/* 使用 CSS 绘制简单图标 */
.icon-home {
  border: 4rpx solid var(--text-gray);
  border-radius: 8rpx;
  position: relative;
}

.icon-home::before {
  content: '';
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  border-left: 28rpx solid transparent;
  border-right: 28rpx solid transparent;
  border-bottom: 20rpx solid var(--text-gray);
}

.icon-home.active {
  border-color: var(--primary-green);
}

.icon-home.active::before {
  border-bottom-color: var(--primary-green);
}

.icon-plant {
  position: relative;
}

.icon-plant::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 16rpx;
  background: var(--text-gray);
  border-radius: 0 0 8rpx 8rpx;
}

.icon-plant::after {
  content: '🌱';
  font-size: 32rpx;
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.icon-plant.active::before {
  background: var(--primary-green);
}

/* 添加日记弹窗 */
.add-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-green);
  z-index: 200;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.add-modal.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  position: relative;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: var(--text-dark);
}

.modal-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-dark);
}

.modal-title-en {
  position: absolute;
  right: 32rpx;
  font-size: 28rpx;
  color: var(--light-green);
  font-style: italic;
}

.modal-body {
  flex: 1;
  padding: 0 32rpx;
  overflow-y: auto;
  position: relative;
}

/* 文本输入区域 */
.text-input-area {
  background: linear-gradient(180deg, #e8f5e9 0%, #f0f7e6 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  min-height: 300rpx;
  margin-bottom: 32rpx;
}

.diary-textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: var(--text-dark);
  background: transparent;
  line-height: 1.6;
}

.textarea-placeholder {
  color: var(--text-light);
}

/* 养护操作选择 */
.action-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-dark);
  font-weight: 500;
  margin-bottom: 20rpx;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  padding: 16rpx 40rpx;
  background: white;
  border: 2rpx solid #ddd;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-gray);
  transition: all 0.2s ease;
}

.action-btn.selected {
  background: var(--light-green);
  border-color: var(--light-green);
  color: white;
}

/* 图片上传区域 */
.image-upload-section {
  margin-bottom: 32rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.uploaded-image-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  object-fit: cover;
}

.remove-image {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--danger-red);
  border-radius: 50%;
  color: white;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: white;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.upload-icon {
  font-size: 56rpx;
  color: var(--text-light);
  line-height: 1;
}

.upload-text {
  font-size: 22rpx;
  color: var(--text-light);
  text-align: center;
}

/* 装饰植物图案 */
.decoration-plants {
  position: absolute;
  bottom: 40rpx;
  right: 32rpx;
  display: flex;
  gap: 16rpx;
  opacity: 0.6;
}

.deco-plant {
  width: 60rpx;
  height: 80rpx;
  position: relative;
}

.deco-plant::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 30rpx;
  background: #d2691e;
  border-radius: 4rpx 4rpx 8rpx 8rpx;
}

.deco-plant::after {
  content: '';
  position: absolute;
  bottom: 25rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 50rpx;
  background: var(--light-green);
  border-radius: 50% 50% 0 0;
}

.plant-2::after {
  width: 20rpx;
  height: 40rpx;
  background: #2e7d32;
}

.plant-3::after {
  width: 35rpx;
  height: 45rpx;
  background: #81c784;
}

/* 完成按钮 */
.modal-footer {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: var(--primary-green);
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}
