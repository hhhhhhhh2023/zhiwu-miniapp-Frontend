/* pages/register/register.wxss */
page {
  background-color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.register-container {
  padding: 120rpx 60rpx 0;
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 背景渐变装饰 */
.register-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: -200rpx;
  width: 600rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 204, 188, 0.4) 0%, rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
  z-index: -1;
}

.register-container::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: -200rpx;
  width: 600rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(255, 204, 188, 0.3) 0%, rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
  z-index: -1;
}

/* 右上角装饰曲线 */
.decor-curve {
  position: absolute;
  top: 0;
  right: 0;
  width: 400rpx;
  height: 300rpx;
  border: 4rpx solid rgba(133, 184, 114, 0.3);
  border-left: none;
  border-bottom: none;
  border-radius: 0 100% 0 0;
  transform: rotate(15deg);
  z-index: -1;
}

/* 标题样式 */
.register-title {
  margin-bottom: 120rpx;
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.title-cn {
  font-size: 64rpx;
  font-weight: 500;
  color: #333;
  position: relative;
}

.title-cn::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 0;
  width: 100%;
  height: 6rpx;
  background-color: #85b872;
}

.title-en {
  font-size: 48rpx;
  font-style: italic;
  color: #85b872;
}

/* 表单样式 */
.register-form {
  margin-bottom: 120rpx;
}

.form-item {
  margin-bottom: 60rpx;
  border-bottom: 1rpx solid #ccc;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 36rpx;
  color: #333;
  padding: 0;
}

/* 按钮样式 */
.register-buttons {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.btn-register {
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(90deg, #3a6e50, #85b872);
  color: #fff;
  font-size: 40rpx;
  border: none;
}

.btn-login {
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  background-color: #fff;
  color: #5a8c4a;
  font-size: 40rpx;
  border: 2rpx solid #85b872;
}

/* 验证码注册入口 */
.sms-register {
  text-align: center;
  font-size: 32rpx;
  color: #85b872;
  margin-bottom: 120rpx;
}

/* 底部Logo（纯CSS实现花盆+叶子） */
.register-footer {
  text-align: center;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.logo-pot {
  position: relative;
  width: 80rpx;
  height: 80rpx;
}

/* 花盆主体 */
.pot-body {
  position: absolute;
  bottom: 0;
  left: 10rpx;
  width: 60rpx;
  height: 40rpx;
  background-color: #e69a6a;
  border-radius: 0 0 10rpx 10rpx;
}

.pot-body::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -5rpx;
  width: 70rpx;
  height: 8rpx;
  background-color: #d48858;
  border-radius: 4rpx;
}

/* 叶子 */
.pot-leaf {
  position: absolute;
  top: 10rpx;
  left: 25rpx;
  width: 30rpx;
  height: 40rpx;
  background-color: #85b872;
  border-radius: 0 50% 0 50%;
  transform: rotate(-30deg);
}

.pot-leaf::after {
  content: '';
  position: absolute;
  top: 5rpx;
  left: 15rpx;
  width: 25rpx;
  height: 30rpx;
  background-color: #5a8c4a;
  border-radius: 0 50% 0 50%;
  transform: rotate(60deg);
}

.logo-text {
  font-size: 56rpx;
  color: #333;
  font-weight: 500;
}