  width: 100%;
  height: 100%;
  z-index: 1;
}
.start-btn {
  position: absolute;
  bottom: 350rpx;
  left: 55%;
  transform: translateX(-50%);
  width: 1200rpx;
  height: 240rpx;
  z-index: 2;
}