page {
  background: #f6f5f1;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 100rpx);
  box-sizing: border-box;
  padding-bottom: 140rpx;
  background: #f6f5f1 url("/images/home-bg.png") center/cover no-repeat;
}

.title-wrap {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.title-cn {
  font-size: 62rpx;
  color: #1e1e1e;
}

.title-en {
  font-size: 54rpx;
  color: #7aa13e;
  font-style: italic;
}

.remind-card {
  position: relative;
  background: #c6d8ae url("/images/garden-remind-bg.png") center/cover no-repeat;
  border-radius: 26rpx;
  padding: 0 20rpx 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.remind-head {
  background: linear-gradient(90deg, #3f6f2b, #547c3f);
  color: #fff;
  font-size: 42rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx 20rpx 0 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}

.head-mark {
  width: 120rpx;
  height: 20rpx;
  margin-top: 8rpx;
}

.remind-item {
  background: #fff;
  border-radius: 999rpx;
  margin-top: 16rpx;
  padding: 14rpx 24rpx;
  font-size: 30rpx;
  color: #1f1f1f;
  flex: 1;
}

.remind-item.done {
  color: #2b6f2d;
}

.remind-item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.check-btn {
  margin-top: 16rpx;
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
}

.chips {
  display: flex;
  gap: 16rpx;
  margin: 18rpx 0;
}

.chip {
  background: #f8b188;
  color: #222;
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.chip-active {
  background: #f39a68;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.card {
  width: calc(50% - 9rpx);
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-img {
  width: 100%;
  height: 250rpx;
  background: rgba(255, 255, 255, 0.7);
}

.card-name {
  font-size: 44rpx;
  color: #1e1e1e;
  padding: 10rpx 18rpx 0;
}

.card-sub {
  font-size: 26rpx;
  color: #4e6547;
  padding: 6rpx 18rpx 18rpx;
}

.fab {
  position: fixed;
  right: 30rpx;
  bottom: 70rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #8fb824;
  color: #fff;
  font-size: 66rpx;
  text-align: center;
  line-height: 96rpx;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.18);
}
